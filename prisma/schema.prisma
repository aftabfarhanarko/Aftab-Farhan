generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plant {
  id          String   @id @default(cuid())
  name        String
  title       String
  subtitle    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  imageUrl    String?
}

// User Data Saved
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Hero Sections
model Hero {
  id          String @id @default(cuid())
  name        String
  title       String
  description String
  image       String

  stats   HeroStat[]
  socials HeroSocial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroStat {
  id    String @id @default(cuid())
  label String
  value String

  heroId String
  hero   Hero   @relation(fields: [heroId], references: [id])
}

model HeroSocial {
  id       String @id @default(cuid())
  platform String
  url      String

  heroId String
  hero   Hero   @relation(fields: [heroId], references: [id])
}


model About {
  id               Int    @id @default(autoincrement())
  fullName         String // Aftab Farhan Arko
  roleTag          String // Full Stack Developer
  roleDescription  String // Full Stack Developer  Specialist in ...

  introParagraphs  Json
  clientFocusedText String
  stats            Json
  frontendSkills   Json
  backendSkills    Json
  tools            Json
  projects         Json
  quoteText        String
  quoteAuthor      String
  mentorTitle       String
  mentorDescription String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}