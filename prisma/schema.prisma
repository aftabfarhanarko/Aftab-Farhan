generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hero {
  id          String       @id @default(cuid())
  name        String
  title       String
  description String
  image       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  socials     HeroSocial[]
  stats       HeroStat[]
}

model HeroStat {
  id     String @id @default(cuid())
  label  String
  value  String
  heroId String
  hero   Hero   @relation(fields: [heroId], references: [id])
}

model HeroSocial {
  id       String @id @default(cuid())
  platform String
  url      String
  heroId   String
  hero     Hero   @relation(fields: [heroId], references: [id])
}

model About {
  id                Int      @id @default(autoincrement())
  fullName          String
  roleTag           String
  roleDescription   String
  introParagraphs   Json
  clientFocusedText String
  stats             Json
  frontendSkills    Json
  backendSkills     Json
  tools             Json
  projects          Json
  quoteText         String
  quoteAuthor       String
  mentorTitle       String
  mentorDescription String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Experience {
  id           Int           @id @default(autoincrement())
  company      String
  url          String
  location     String
  period       String
  type         String
  techStack    String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  achievements Achievement[]
  roles        Role[]
}

model Role {
  id               Int        @id @default(autoincrement())
  title            String
  subtitle         String
  iconName         String
  responsibilities String[]
  experienceId     Int
  experience       Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Achievement {
  id           Int        @id @default(autoincrement())
  metric       String
  label        String
  experienceId Int
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model SkillCategory {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skills    Skill[]
}

model Skill {
  id         String        @id @default(uuid())
  name       String
  imageUrl   String?
  categoryId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  category   SkillCategory @relation(fields: [categoryId], references: [id])
}

model Education {
  id          String   @id @default(uuid())
  degree      String
  field       String
  institution String
  shortName   String?
  location    String
  period      String
  grade       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String         @id @default(uuid())
  name      String
  email     String
  subject   ContactSubject
  message   String
  status    MessageStatus  @default(UNREAD)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Project {
  id          String          @id @default(uuid())
  title       String
  tagline     String
  description String
  image       String
  demoLink    String
  githubLink  String?
  category    ProjectCategory
  year        String
  featured    Boolean         @default(false)
  projectType ProjectType
  client      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tech        ProjectTech[]
}

model Tech {
  id       String        @id @default(uuid())
  name     String        @unique
  projects ProjectTech[]
}

model ProjectTech {
  id        String  @id @default(uuid())
  projectId String
  techId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tech      Tech    @relation(fields: [techId], references: [id], onDelete: Cascade)

  @@unique([projectId, techId])
}

enum ContactSubject {
  FREELANCE
  FULLTIME
  COLLABORATION
  CONSULTING
  OTHER
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum ProjectType {
  MY
  TEAM
  CLIENT
}

enum ProjectCategory {
  FULL_STACK
  AI_ML
  FRONTEND
  E_COMMERCE
  HEALTHCARE
  REAL_ESTATE
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String?       // Optional reference to a logged-in user
  userName  String        @default("Visitor")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "assistant"
  content   String
  createdAt DateTime    @default(now())
}

